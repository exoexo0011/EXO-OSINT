# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Local env files (commit .env.example instead)
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# The repository root .gitignore ignores any `lib/` directory (a Python build
# convention). Our React source lives in src/lib/, so re-include it here —
# otherwise frontend/src/lib/results.js gets silently dropped from commits.
!src/lib/
!src/lib/**
